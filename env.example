# ── STRIPE ──────────────────────────────────────────────────
# Deine Stripe Secret Key (von https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_DEIN_KEY_HIER

# Webhook Secret (von https://dashboard.stripe.com/webhooks)
# Lokal testen: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_DEIN_SECRET_HIER

# Price ID deines 5,99€/Monat Produkts (Stripe Dashboard → Products)
STRIPE_PRICE_ID=price_DEIN_PRICE_ID_HIER

# ── AUTH ─────────────────────────────────────────────────────
# Mindestens 32 zufällige Zeichen! Generieren mit:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=HIER_EINEN_LANGEN_ZUFAELLIGEN_STRING_EINTRAGEN

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── FRONTEND URL ─────────────────────────────────────────────
# Deine Domain (kein trailing slash)
CLIENT_URL=https://deine-domain.de
